{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "showMe",
  "version": "0.0.1",
  "identifier": "app.showme.terminal",
  "build": {
    "beforeDevCommand": "npm --workspace ui run dev",
    "beforeBuildCommand": "npm --workspace ui run build",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "showMe",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar", "underWindowBackground"],
          "state": "active"
        },
        "trafficLightPosition": { "x": 14, "y": 18 },
        "shadow": true,
        "acceptFirstMouse": false,
        "tabbingIdentifier": "showme.terminal"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: https://ipc.localhost; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "public.app-category.finance",
    "shortDescription": "Trader cockpit — native macOS",
    "longDescription": "showMe is a native macOS Apple Silicon trader cockpit powered by a bundled 138+ function market engine in a Tauri shell with native menus, tray, notifications, biometric auth, and multi-window state.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "exceptionDomain": "",
      "providerShortName": null,
      "signingIdentity": null,
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    },
    "externalBin": ["binaries/showme-backend"],
    "resources": [],
    "fileAssociations": []
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["showme"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/showme-app/showme/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "PLACEHOLDER_REPLACE_WITH_TAURI_GENERATED_KEY",
      "windows": {
        "installMode": "passive"
      }
    },
    "global-shortcut": null
  }
}
