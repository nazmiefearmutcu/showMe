{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "showMe",
  "version": "0.0.1",
  "identifier": "app.showme.terminal",
  "build": {
    "beforeDevCommand": "npm --workspace ui run dev",
    "beforeBuildCommand": "npm --workspace ui run build",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "showMe",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "windowEffects": {
          "effects": [
            "sidebar",
            "underWindowBackground"
          ],
          "state": "active"
        },
        "shadow": true,
        "acceptFirstMouse": false,
        "tabbingIdentifier": "showme.terminal"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: https://ipc.localhost; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:*; object-src 'none'; frame-src 'none'; worker-src 'self' blob:; base-uri 'self'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "public.app-category.finance",
    "shortDescription": "Trader cockpit \u2014 native macOS",
    "longDescription": "showMe is a native macOS Apple Silicon trader cockpit powered by a bundled 138+ function market engine in a Tauri shell with native menus, tray, notifications, biometric auth, and multi-window state.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "exceptionDomain": "",
      "providerShortName": null,
      "signingIdentity": null,
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    },
    "externalBin": [],
    "resources": [
      "binaries/showme-backend/**/*"
    ],
    "fileAssociations": []
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "showme"
        ]
      }
    },
    "updater": {
      "_comment_pubkey": "Round 4C — real minisign keypair generated via `tauri signer generate`. Private half lives at packaging/keys/showme-updater.key (gitignored). CI must inject TAURI_SIGNING_PRIVATE_KEY + TAURI_SIGNING_PRIVATE_KEY_PASSWORD to sign release artifacts.",
      "active": true,
      "endpoints": [
        "https://github.com/nazmiefearmutcu/showMe/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4MjREQjMxQzlGQjMxNkUKUldSdU1mdkpNZHNrbUw3VlRwMGZ4bE9lNi9qdC8zR1V1bzMzVjE0TkJkdFBka1g3YUtJa1dJalcK",
      "windows": {
        "installMode": "passive"
      }
    },
    "global-shortcut": null
  }
}
