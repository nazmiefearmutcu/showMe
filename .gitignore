# ─────────────────────────────────────────────────────────────────────────────
# showMe — version control hygiene
# ─────────────────────────────────────────────────────────────────────────────

# OS
.DS_Store
Thumbs.db
*.swp
*~

# Editor / IDE
.vscode/
.idea/
*.iml
.claude/

# Secrets
.env
.env.*
!.env.example

# ── Node / UI ───────────────────────────────────────────────────────────────
node_modules/
ui/dist/
ui/.vite/
ui/*.tsbuildinfo
src-ui/dist/
src-ui/.vite/
src-ui/*.tsbuildinfo

# ── Rust / Tauri ────────────────────────────────────────────────────────────
tauri/target/
tauri/binaries/
src-tauri/target/
src-tauri/binaries/
**/*.rs.bk

# ── Python / Backend ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
backend/build/
backend/dist/
src-py/build/
src-py/dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Build / packaging output ────────────────────────────────────────────────
dist/
build/
*.dmg
*.pkg
*.app/

# ── Generated / runtime state ───────────────────────────────────────────────
runtime/
*/runtime/
backend/showme/runtime/

# ── Test / audit artifacts ──────────────────────────────────────────────────
artifacts/
output/
test-artifacts/
test-results/
playwright-report/
.playwright-cli/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docs scratch ────────────────────────────────────────────────────────────
docs/round_notes/screenshots/
packaging/keys/
packaging/keys/*.key

# ── ML model weights (too large for git — fetched at build time) ────────────
x_scraper_ai/model/

# ── Fakery-ban baseline (generated by tests/test_production_fakery_banned.py) ─
# Local-only ceiling that ratchets downward; never committed. The shape
# reference lives at tests/_fakery_baseline.example.json.
tests/_fakery_baseline.json

# Coverage artifacts (rebuild 2026-05-25)
backend/.coverage
backend/coverage.xml

# UI coverage artifact directory (vitest --coverage)
ui/coverage/
